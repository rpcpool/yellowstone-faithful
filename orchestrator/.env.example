# AWS/S3 Configuration
AWS_ENDPOINT=s3.us-east-2.wasabisys.com
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key

# Database Configuration
DATABASE_URL=postgresql://username:password@host:port/database?schema=public

# HTTP Index Service Configuration
INDEX_HOST=http://localhost:8080
INDEX_USER=your_index_username
INDEX_PASS=your_index_password

# Faktory Configuration
FAKTORY_URL=tcp://localhost:7419

# Faithful CLI Configuration
FAITHFUL_CLI_PATH=/path/to/faithful-cli

# GSFA Index Configuration
GSFA_INDEX_RESERVE_FOR=172800