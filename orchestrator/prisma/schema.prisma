// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum IndexType {
  CidToOffsetAndSize
  SigExists
  SigToCid
  SlotToBlocktime
  SlotToCid
}

enum IndexStatus {
  NotProcessed
  Processing
  Present
}

enum EpochStatus {
  NotProcessed
  Processing
  Indexed
  Complete
}

enum JobStatus {
  queued
  processing
  completed
  failed
}

model Epoch {
  id        Int      @id
  epoch     String   @unique
  status    EpochStatus
  cid       String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  jobs        Job[]
  epochIndexes EpochIndex[]
  epochGsfas   EpochGsfa[]
}

model EpochIndex {
  id        Int      @id @default(autoincrement())
  epoch     String
  type      IndexType
  size      BigInt
  status    String
  location  String
  source    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  epochRecord Epoch @relation(fields: [epoch], references: [epoch])

  @@unique([epoch, type, source])
}

model EpochGsfa {
  id        Int      @id
  epoch     String
  exists    Boolean? @default(false)
  location  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  epochRecord Epoch @relation(fields: [epoch], references: [epoch])
}

model Job {
  id        String    @id
  epochId   Int       @map("epoch_id")
  jobType   String    @map("job_type")
  status    JobStatus
  metadata  Json?
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  // Relations
  epoch     Epoch     @relation(fields: [epochId], references: [id])

  @@map("jobs")
}